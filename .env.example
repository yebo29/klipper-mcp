# Klipper MCP Server - environment file template
#
# Copy this file to .env and edit. config.py loads it automatically on startup
# (via python-dotenv). Values are OPTIONAL - anything omitted falls back to the
# default in config.py.
#
#   cp .env.example .env
#   nano .env
#
# Precedence: variables already set in the real environment (shell export or a
# systemd drop-in) win over values in this file. Do NOT commit your real .env -
# it is gitignored because it holds secrets.

# =============================================================================
# GENERAL
# =============================================================================
MOONRAKER_URL=http://localhost:7125
PRINTER_NAME=Voron

# =============================================================================
# MCP SERVER
# =============================================================================
MCP_PORT=8000

# =============================================================================
# SECURITY - change these!
# =============================================================================
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CHANGE-ME-TO-A-SECURE-KEY
ARMED=false
READ_ONLY=false
ADMIN_PIN=123456

# =============================================================================
# FILE PATHS (override only for non-standard layouts)
# =============================================================================
# PRINTER_DATA_PATH=/home/pi/printer_data

# =============================================================================
# CAMERA
# =============================================================================
CAMERA_SNAPSHOT_URL=http://localhost/webcam/?action=snapshot
CAMERA_STREAM_URL=http://localhost/webcam/?action=stream

# =============================================================================
# SPOOLMAN (optional filament tracking)
# =============================================================================
SPOOLMAN_ENABLED=false
SPOOLMAN_URL=http://localhost:7912

# =============================================================================
# NOTIFICATIONS (all optional)
# =============================================================================
NTFY_ENABLED=false
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=voron-printer

DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

SLACK_WEBHOOK_URL=

PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# Text-to-speech (needs pyttsx3 + a speaker on the CB1/Pi)
TTS_ENABLED=false
TTS_RATE=150
TTS_VOLUME=0.8

# =============================================================================
# TOOLCHANGER
# =============================================================================
TOOL_COUNT=1
